NODE_ENV=development
PORT=5000

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/healthcare-iot

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Feature flags
ENABLE_MOCK_DATA=true
MOCK_AMBULANCE_COUNT=6
